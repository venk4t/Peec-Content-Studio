# ─────────────────────────────────────────────────────────────────────────
# Peec MCP — legacy direct-token path (optional)
# Live data is fetched dynamically via vendor/peec_mcp_auth.py (DCR + PKCE
# OAuth flow). Tokens are cached on disk at data/.peec_tokens.json after a
# one-time `python3 vendor/list_projects.py` browser login. Leave blank
# unless you have a service token from Peec.
# ─────────────────────────────────────────────────────────────────────────
PEEC_MCP_URL=
PEEC_MCP_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# External API integrations (required at runtime)
# ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
TAVILY_API_KEY=
PIONEER_API_KEY=
PIONEER_MODEL_ID=

# ─────────────────────────────────────────────────────────────────────────
# Dynamic project data loader
# ─────────────────────────────────────────────────────────────────────────
# When "true", lib/peec.ts falls back to the static data/peec-snapshot.ts
# whenever the live JSON file for the selected project is missing.
# Useful for offline demos. Default: false.
USE_FALLBACK_SNAPSHOT=false

# ─────────────────────────────────────────────────────────────────────────
# Python interpreter (optional override)
# ─────────────────────────────────────────────────────────────────────────
# The /api/peec/* routes spawn Python scripts under vendor/. By default
# the resolver tries: python3 → python (POSIX) and python → py -3 →
# python3 (Windows). Set this only if your interpreter lives somewhere
# else, e.g. PYTHON_BIN="/usr/local/bin/python3.11" or PYTHON_BIN="py -3".
PYTHON_BIN=
